)

result = {
    "schema_version": 1,
    "task": "AJM006_V02_PARASOLID_TOPOLOGY_OBSERVER",
    "probe": "v02_parasolid_topology_observer",
    "status": "FAIL_PRELIMINARY_PARASOLID_OBSERVER",
    "engineering_capability": "FAIL_PRELIMINARY_PARASOLID_OBSERVER",
    "formal_006_completion": False,
    "p1_stage_gate": "NOT_RUN",
