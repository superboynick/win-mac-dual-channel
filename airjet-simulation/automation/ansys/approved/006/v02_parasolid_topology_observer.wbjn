    }
    predecessor_identity_ok = (
        predecessor_manifest.get("schema_version") == 1
        and predecessor_manifest.get("required_report")
        == "v02_parasolid_converter.json"
        and predecessor_manifest.get("required_status")
        == "PASS_PARTIAL_CAD_CAPABILITY"
        and predecessor_manifest.get("predecessor_profile_id")
        == EXPECTED_PREDECESSOR_PROFILE
        and predecessor_manifest.get("git_head")
        == os.environ.get("AIRJET_GIT_HEAD")
        and converter.get("probe") == "v02_parasolid_converter"
        and converter.get("status") == "PASS_PARTIAL_CAD_CAPABILITY"
        and converter.get("engineering_capability")
        == "PASS_PARTIAL_CAD_CAPABILITY"
        and converter.get("formal_006_completion") is False
        and converter.get("p1_stage_gate") == "NOT_RUN"
        and converter.get("p1_p6_gates") == "NOT_RUN"
        and converter.get("license_arguments_added") is False
        and converter.get("diagnostic_only") is True
        and converter.get("mesh") == "NOT_RUN"
        and converter.get("physics") == "NOT_RUN"
        and converter.get("source_native_mutated") is False
        and converter.get("representation_conversion") is True
        and converter.get("interface_topology")
        == "NOT_EVALUATED_UNTIL_PARASOLID_OBSERVER"
        and converter.get("identity", {}).get("git_head")
        == os.environ.get("AIRJET_GIT_HEAD")
        and converter.get("identity", {}).get("profile_id")
        == EXPECTED_PREDECESSOR_PROFILE
        and converter.get("identity", {}).get("case_id")
        == os.environ.get("AIRJET_CASE_ID")
        and converter.get("identity", {}).get("script_sha256")
        == predecessor_manifest.get("predecessor_script_sha256")
        and converter.get("identity", {}).get("profile_contract_sha256")
        == predecessor_manifest.get("predecessor_profile_contract_sha256")
        and set(converter.get("assertions", {})) == set(REQUIRED_ASSERTIONS)
        and all(
            converter.get("assertions", {}).get(name) is True
            for name in REQUIRED_ASSERTIONS
        )
        and set(manifest_entries) == expected_names
        and set(predecessor_snapshot_before)
        == expected_predecessor_tree_names
        and all(
            manifest_entries.get(name, {}).get("sha256")
            == actual_hashes.get(name)
            and manifest_entries.get(name, {}).get("size")
            == os.path.getsize(actual_paths[name])
            for name in expected_names
        )
        and all(
            converter_files.get(role, {}).get("sha256")
            == actual_hashes.get(name)
            and converter_files.get(role, {}).get("size")
            == os.path.getsize(actual_paths[name])
            for role, name in role_to_name.items()
        )
        and face_inventory.get("claim_scope")
        == "V02_PRELIMINARY_GEOMETRY_ONLY"
        and face_inventory.get("downstream_orifice_candidates")
        == EXPECTED_ORIFICE_COUNT
        and source_chain.get("producer_git_head")
        == os.environ.get("AIRJET_GIT_HEAD")
        and source_chain.get("producer_profile_id")
        == "ajm006-spaceclaim-v02-preliminary-v1"
        and source_chain.get("parasolid", {}).get("sha256")
        == actual_hashes["product.x_t"]
        and source_chain.get("parasolid", {}).get("size")
        == os.path.getsize(geometry_path)
        and source_chain.get("source_hashes", {}).get(
            "v02_face_inventory.json"
        )
        == actual_hashes["v02_face_inventory.json"]
        and parasolid_reimport.get("body_count") == 2
        and parasolid_reimport.get("route")
        == "SPACECLAIM_NATIVE_TO_PARASOLID_X_T_AND_REOPEN"
        and parasolid_reimport.get("solver_interface_identity")
        == "NOT_EVALUATED_UNTIL_PARASOLID_OBSERVER"
        and sorted(
            item.get("face_count")
            for item in parasolid_reimport.get("body_fingerprints", [])
        )
        == [978, 2044]
    )
    result["predecessor"] = {
        "job_id": predecessor_manifest.get("predecessor_job_id"),
        "profile_id": predecessor_manifest.get("predecessor_profile_id"),
        "git_head": predecessor_manifest.get("git_head"),
        "artifact_manifest_snapshot_sha256": predecessor_manifest.get(
            "artifact_manifest_snapshot_sha256"
        ),
        "parasolid_sha256": actual_hashes.get("product.x_t"),
        "source_native_face_counts": sorted(
            item.get("face_count")
            for item in source_chain.get("native_open_fingerprints", [])
        ),
        "source_parasolid_face_counts": sorted(
            item.get("face_count")
            for item in parasolid_reimport.get("body_fingerprints", [])
        ),
