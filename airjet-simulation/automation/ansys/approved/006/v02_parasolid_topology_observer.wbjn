}


def sha256_file(path):
    digest = hashlib.sha256()
    with open(path, "rb") as handle:
        while True:
            chunk = handle.read(1024 * 1024)
            if not chunk:
                break
            digest.update(chunk)
    return digest.hexdigest()


def snapshot_tree(root):
    snapshot = {}
    for base, directories, files in os.walk(root):
        directories.sort()
        files.sort()
        for name in files:
            path = os.path.join(base, name)
            relative = os.path.relpath(path, root).replace("\\", "/")
            snapshot[relative] = {
                "size": os.path.getsize(path),
                "sha256": sha256_file(path),
            }
    return snapshot


def read_json(path):
    with open(path, "r") as handle:
        value = json.load(handle)
    if not isinstance(value, dict):
        raise Exception("JSON_ROOT_NOT_OBJECT:%s" % os.path.basename(path))
    return value


try:
    converter = read_json(converter_report_path)
    face_inventory = read_json(face_inventory_path)
    source_chain = read_json(source_chain_path)
    parasolid_reimport = read_json(parasolid_reimport_path)
    predecessor_manifest = read_json(predecessor_manifest_path)
    manifest_entries = dict(
        (item.get("relative_path"), item)
        for item in predecessor_manifest.get("artifacts", [])
    )
    expected_names = {
        "v02_parasolid_converter.json",
        "product.x_t",
        "v02_face_inventory.json",
        "source_chain.json",
        "parasolid_reimport.json",
    }
    expected_predecessor_tree_names = set(expected_names)
    expected_predecessor_tree_names.add("predecessor-manifest.json")
    actual_paths = {
        "v02_parasolid_converter.json": converter_report_path,
        "product.x_t": geometry_path,
        "v02_face_inventory.json": face_inventory_path,
        "source_chain.json": source_chain_path,
        "parasolid_reimport.json": parasolid_reimport_path,
    }
    actual_hashes = dict(
        (name, sha256_file(path)) for name, path in actual_paths.items()
    )
    predecessor_snapshot_before = snapshot_tree(predecessor_dir)
    converter_files = converter.get("files", {})
    role_to_name = {
        "parasolid": "product.x_t",
        "face_inventory": "v02_face_inventory.json",
        "source_chain": "source_chain.json",
